generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InteractionStatus {
  watched
  watching
  want_to_watch
  dropped
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique @db.VarChar(30)
  passwordHash  String   @map("password_hash")
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  movieInteractions   UserMovieInteraction[]
  tvInteractions      UserTvInteraction[]
  achievements        UserAchievement[]
  sessions            UserSession[]
  userReviews         UserReview[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([tokenHash])
  @@map("user_sessions")
}

model Movie {
  id          String   @id @default(uuid())
  tmdbId      Int      @unique @map("tmdb_id")
  title       String
  overview    String?
  posterPath  String?  @map("poster_path")
  backdropPath String? @map("backdrop_path")
  releaseDate DateTime? @map("release_date")
  runtime     Int?
  voteAverage Float?   @map("vote_average")
  voteCount   Int?     @map("vote_count")
  genres      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interactions UserMovieInteraction[]
  @@index([tmdbId])
  @@map("movies")
}

model TvSeries {
  id           String   @id @default(uuid())
  tmdbId       Int      @unique @map("tmdb_id")
  name         String
  overview     String?
  posterPath   String?  @map("poster_path")
  backdropPath String?  @map("backdrop_path")
  firstAirDate DateTime? @map("first_air_date")
  lastAirDate  DateTime? @map("last_air_date")
  voteAverage  Float?   @map("vote_average")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  interactions UserTvInteraction[]
  @@index([tmdbId])
  @@map("tv_series")
}

model UserMovieInteraction {
  id         String            @id @default(uuid())
  userId     String            @map("user_id")
  movieId    String            @map("movie_id")
  status     InteractionStatus?
  rating     Decimal?          @db.Decimal(3, 1)
  isFavorite Boolean           @default(false) @map("is_favorite")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("user_movie_interactions")
}

model UserTvInteraction {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  seriesId         String            @map("series_id")
  status           InteractionStatus?
  rating           Decimal?          @db.Decimal(3, 1)
  currentSeason    Int?              @map("current_season")
  currentEpisode   Int?              @map("current_episode")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series TvSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@index([userId])
  @@index([status])
  @@map("user_tv_interactions")
}

model UserReview {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  tmdbId          Int      @map("tmdb_id")
  title           String?
  content         String
  rating          Float?
  likesCount      Int      @default(0) @map("likes_count")
  containsSpoilers Boolean @default(false) @map("contains_spoilers")
  contentType     String   @default("movie") @map("content_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  ReviewLike[]

  @@unique([userId, tmdbId, contentType])
  @@index([userId])
  @@index([tmdbId])
  @@index([contentType])
  @@map("user_reviews")
}

model ReviewLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  reviewId  String   @map("review_id")
  createdAt DateTime @default(now()) @map("created_at")

  review UserReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@map("review_likes")
}

model UserAchievement {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  achievementCode String   @map("achievement_code") @db.VarChar(50)
  earnedAt        DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementCode])
  @@index([userId])
  @@map("user_achievements")
}

model News {
  id          String   @id @default(uuid())
  tmdbId      Int?     @map("tmdb_id")
  externalId String?  @map("external_id")
  title       String
  link       String?
  snippet    String?
  imageUrl    String?  @map("image_url")
  sourceName  String   @map("source_name")
  pubDate     DateTime @map("pub_date")
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([pubDate])
  @@index([sourceName])
  @@map("news")
}